{
  "version": 1,
  "primaryRoutes": [
    { "path": "/", "label": "dashboard" },
    { "path": "/onboarding", "label": "onboarding" },
    { "path": "/gameplay", "label": "gameplay hub" },
    { "path": "/gameplay/quick", "label": "quick game" },
    { "path": "/gameplay/pilots", "label": "pilot roster" },
    { "path": "/gameplay/pilots/create", "label": "create pilot" },
    { "path": "/gameplay/forces", "label": "force roster" },
    { "path": "/gameplay/forces/create", "label": "create force" },
    { "path": "/gameplay/campaigns", "label": "campaigns" },
    { "path": "/gameplay/campaigns/create", "label": "create campaign" },
    { "path": "/gameplay/encounters", "label": "encounters" },
    { "path": "/gameplay/encounters/create", "label": "create encounter" },
    { "path": "/gameplay/games", "label": "games" },
    { "path": "/gameplay/repair", "label": "repair bay" },
    { "path": "/compendium", "label": "compendium" },
    { "path": "/compendium/units", "label": "compendium units" },
    { "path": "/compendium/equipment", "label": "compendium equipment" },
    { "path": "/compendium/rules", "label": "compendium rules" },
    { "path": "/units", "label": "custom units" },
    { "path": "/customizer", "label": "customizer" },
    { "path": "/compare", "label": "unit comparison" },
    { "path": "/multiplayer", "label": "multiplayer" },
    { "path": "/audit/timeline", "label": "event timeline" },
    { "path": "/replay-library", "label": "replay library" },
    { "path": "/share", "label": "share links" },
    { "path": "/contacts", "label": "vault contacts" },
    { "path": "/shared", "label": "shared items" },
    { "path": "/settings#vault", "label": "settings vault hash" },
    { "path": "/settings", "label": "settings" }
  ],
  "recoveryRoutes": [
    {
      "path": "/share/e2e-missing-token",
      "pattern": "/share/[token]",
      "label": "invalid share token"
    },
    {
      "path": "/app-shell-e2e-missing-route",
      "pattern": "/404",
      "label": "global not found"
    }
  ],
  "delegatedRoutes": [
    {
      "label": "compendium data-backed detail routes",
      "patterns": [
        "/compendium/equipment/[id]",
        "/compendium/rules/[id]",
        "/compendium/units/[id]"
      ],
      "proofCommand": "node scripts/playwright/run-playwright.mjs test --project=chromium e2e/compendium.spec.ts e2e/audit-capture.spec.ts --workers=1",
      "proofTests": ["e2e/compendium.spec.ts", "e2e/audit-capture.spec.ts"],
      "reason": "Catalog and rules detail routes need stable catalog-backed IDs or screenshot fixtures before the route can prove useful recovery state."
    },
    {
      "label": "campaign generated detail and subsystem routes",
      "patterns": [
        "/gameplay/campaigns/[id]",
        "/gameplay/campaigns/[id]/acquisitions",
        "/gameplay/campaigns/[id]/contract-market",
        "/gameplay/campaigns/[id]/finances",
        "/gameplay/campaigns/[id]/forces",
        "/gameplay/campaigns/[id]/gm-ledger",
        "/gameplay/campaigns/[id]/hiring",
        "/gameplay/campaigns/[id]/log",
        "/gameplay/campaigns/[id]/mech-bay",
        "/gameplay/campaigns/[id]/medical-bay",
        "/gameplay/campaigns/[id]/missions",
        "/gameplay/campaigns/[id]/missions/[missionId]/launch",
        "/gameplay/campaigns/[id]/personnel",
        "/gameplay/campaigns/[id]/prestige-morale",
        "/gameplay/campaigns/[id]/repair-bay",
        "/gameplay/campaigns/[id]/salvage",
        "/gameplay/campaigns/[id]/starmap"
      ],
      "proofCommand": "npm.cmd run verify:qc:campaign-economy:browser && npm.cmd run qc:campaign-long:browser && node scripts/playwright/run-playwright.mjs test --project=chromium e2e/playtest-campaign-smoke.spec.ts e2e/playtest-subsystem-contracts.spec.ts e2e/playtest-subsystem-hiring.spec.ts e2e/playtest-subsystem-loans.spec.ts --workers=1",
      "proofTests": [
        "e2e/campaign-flow.spec.ts",
        "e2e/campaign-economy-browser.spec.ts",
        "e2e/campaign-acquisition-browser.spec.ts",
        "e2e/campaign-long-browser-signoff.spec.ts",
        "e2e/gm-campaign-ledger-control-plane.spec.ts",
        "e2e/playtest-campaign-smoke.spec.ts",
        "e2e/playtest-subsystem-contracts.spec.ts",
        "e2e/playtest-subsystem-hiring.spec.ts",
        "e2e/playtest-subsystem-loans.spec.ts"
      ],
      "reason": "Campaign subroutes require generated campaign IDs, roster state, contracts, economy state, or GM ledger projections."
    },
    {
      "label": "encounter generated detail and launch routes",
      "patterns": [
        "/gameplay/encounters/[id]",
        "/gameplay/encounters/[id]/pre-battle",
        "/gameplay/encounters/[id]/sim"
      ],
      "proofCommand": "npm.cmd run verify:qc:encounter-combat-continuity && node scripts/playwright/run-playwright.mjs test --project=chromium e2e/encounter-flow.spec.ts e2e/encounter.spec.ts --workers=1",
      "proofTests": [
        "e2e/encounter-flow.spec.ts",
        "e2e/encounter.spec.ts",
        "e2e/encounter-combat-continuity.spec.ts"
      ],
      "reason": "Encounter detail, pre-battle, and sim routes need seeded forces or campaign mission context before they can prove useful state."
    },
    {
      "label": "force and pilot generated detail routes",
      "patterns": ["/gameplay/forces/[id]", "/gameplay/pilots/[id]"],
      "proofCommand": "node scripts/playwright/run-playwright.mjs test --project=chromium e2e/force.spec.ts e2e/replay-player.spec.ts --workers=1",
      "proofTests": [
        "e2e/force.spec.ts",
        "e2e/replay-player.spec.ts",
        "e2e/audit-capture.spec.ts"
      ],
      "reason": "Force and pilot detail routes require a generated roster object to prove title, tabs, recovery state, and actions."
    },
    {
      "label": "game session, replay, report, review, and victory routes",
      "patterns": [
        "/gameplay/games/[id]",
        "/gameplay/games/[id]/replay",
        "/gameplay/games/[id]/review",
        "/gameplay/games/[id]/victory",
        "/gameplay/matches/[id]"
      ],
      "proofCommand": "npm.cmd run verify:qc:replay-recovery && node scripts/playwright/run-playwright.mjs test --project=chromium e2e/game.spec.ts e2e/quick-play.spec.ts e2e/encounter-combat-continuity.spec.ts --workers=1",
      "proofTests": [
        "e2e/active-session-recovery.spec.ts",
        "e2e/replay-player.spec.ts",
        "e2e/game.spec.ts",
        "e2e/quick-play.spec.ts",
        "e2e/encounter-combat-continuity.spec.ts"
      ],
      "reason": "Game-state routes depend on IndexedDB match logs, completed match reports, or launched session state."
    },
    {
      "label": "multiplayer lobby and spectate routes",
      "patterns": [
        "/gameplay/lobby/[roomCode]",
        "/multiplayer/lobby/[roomCode]",
        "/multiplayer/spectate/[matchId]"
      ],
      "proofCommand": "npm.cmd run verify:qc:multiplayer:browser",
      "proofTests": [
        "e2e/p2p-sync.spec.ts",
        "e2e/playtest-mp-smoke.spec.ts",
        "e2e/playtest-coop-route-smoke.spec.ts",
        "e2e/multiplayer-live-vault-auth.spec.ts"
      ],
      "reason": "Lobby and spectate routes require room codes, signed vault identity, or live multiplayer runtime state."
    },
    {
      "label": "custom unit generated detail route",
      "patterns": ["/units/[id]"],
      "proofCommand": "node scripts/playwright/run-playwright.mjs test --project=chromium e2e/customizer.spec.ts e2e/audit-capture.spec.ts --workers=1",
      "proofTests": ["e2e/customizer.spec.ts", "e2e/audit-capture.spec.ts"],
      "reason": "Custom unit detail routes need a generated saved unit before page identity and action recovery are meaningful."
    }
  ],
  "knownGapRoutes": [],
  "testHarnessRoutes": [
    {
      "label": "development and E2E-only harness routes",
      "patterns": [
        "/e2e/intel-tier-projection",
        "/e2e/simulation-viewer",
        "/e2e/sync-test",
        "/e2e/tactical-map"
      ],
      "proofCommand": "node scripts/playwright/run-playwright.mjs test --project=chromium e2e/intel-tier-projection.spec.ts e2e/simulation-viewer.spec.ts e2e/p2p-sync.spec.ts e2e/tactical-map-visual-smoke.spec.ts --workers=1",
      "proofTests": [
        "e2e/intel-tier-projection.spec.ts",
        "e2e/simulation-viewer.spec.ts",
        "e2e/p2p-sync.spec.ts",
        "e2e/tactical-map-visual-smoke.spec.ts"
      ],
      "reason": "These routes are gated by development/test environment checks and are owned by focused browser harness specs instead of public app-shell navigation."
    }
  ],
  "desktopDropdowns": [
    {
      "label": "Browse",
      "items": [
        { "label": "My Units", "path": "/units" },
        { "label": "Compendium", "path": "/compendium" }
      ]
    },
    {
      "label": "Tools",
      "items": [
        { "label": "Customizer", "path": "/customizer" },
        { "label": "Compare", "path": "/compare" }
      ]
    },
    {
      "label": "Gameplay",
      "items": [
        { "label": "Quick Game", "path": "/gameplay/quick" },
        { "label": "Pilots", "path": "/gameplay/pilots" },
        { "label": "Forces", "path": "/gameplay/forces" },
        { "label": "Campaigns", "path": "/gameplay/campaigns" },
        { "label": "Encounters", "path": "/gameplay/encounters" },
        { "label": "Games", "path": "/gameplay/games" },
        { "label": "Multiplayer", "path": "/multiplayer" }
      ]
    },
    {
      "label": "History",
      "items": [
        { "label": "Timeline", "path": "/audit/timeline" },
        { "label": "Replay Library", "path": "/replay-library" }
      ]
    }
  ],
  "mobileNavItems": [
    { "label": "Home", "path": "/" },
    { "label": "Browse", "path": "/compendium" },
    { "label": "Gameplay", "path": "/gameplay" },
    { "label": "Multiplayer", "path": "/multiplayer" },
    { "label": "Settings", "path": "/settings" }
  ]
}
