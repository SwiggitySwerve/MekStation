{
  "version": 1,
  "title": "MekStation end-to-end journey validation scenarios",
  "defaultTier": "standard",
  "evidenceDir": ".sisyphus/evidence/qc-journeys",
  "requiredJourneyIds": [
    "character-build",
    "mek-build",
    "combat-1v1",
    "combat-4v4",
    "contract-campaign",
    "campaign-short",
    "campaign-long"
  ],
  "tiers": {
    "smoke": "Fast deterministic proof that the journey can generate inputs and reach a terminal evidence state.",
    "standard": "Default repeatable journey proof for local and PR review.",
    "extended": "Longer matrix or campaign coverage for release-grade confidence."
  },
  "journeys": [
    {
