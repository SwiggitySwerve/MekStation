      "displayName": "Character build",
      "module": "roster",
      "surfaceIds": ["force-pilot-encounter-setup"],
      "tiers": ["smoke", "standard"],
      "defaultMode": "headless",
      "expectedTerminalState": "character-exported",
      "commandScreenCheckpoints": [
        {
          "id": "pilot-create-command",
          "uiCheckpointId": "pilot-create",
          "label": "Pilot creation command",
          "role": "player",
          "assertions": [
            "Pilot validation blockers and export intent are visible before creation commits."
          ]
        },
        {
          "id": "pilot-roster-review",
          "uiCheckpointId": "pilot-roster",
          "label": "Pilot roster review",
          "role": "player",
          "assertions": [
            "Created pilots are visible in the roster before assignment."
          ]
        },
        {
          "id": "force-assignment-command",
          "uiCheckpointId": "force-assignment",
          "label": "Force assignment command",
          "role": "player",
          "assertions": [
            "Pilot assignment decisions can be checked before combat or campaign use."
