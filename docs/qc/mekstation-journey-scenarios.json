        "pilot-abilities": { "type": "string-list", "default": ["none"] },
        "export-format": {
          "type": "enum",
          "default": "json",
          "values": ["json", "markdown"]
        }
      },
      "steps": [
        {
          "id": "generate-character",
          "title": "Generate pilot or character input",
          "kind": "character-generation",
          "required": true,
          "diagnosticEvent": "character.created",
          "loggingPathId": "character-pilot-creation",
          "executionBacking": "hybrid-command",
          "syntheticBacking": false,
          "executionEvidenceSource": "package:verify:qc:character-build",
          "executionProofCommands": ["npm.cmd run verify:qc:character-build"],
          "produces": ["generated/character.json"]
        },
        {
          "id": "validate-character-export",
          "title": "Validate character export evidence",
          "kind": "artifact-validation",
          "required": true,
          "diagnosticEvent": "character.exported",
          "loggingPathId": "store-persistence-recovery",
          "executionBacking": "hybrid-command",
          "syntheticBacking": false,
          "executionEvidenceSource": "package:verify:qc:character-build",
          "executionProofCommands": ["npm.cmd run verify:qc:character-build"],
          "produces": ["artifacts/character-export.json"]
        }
      ],
      "evidenceAssertions": [
        "generated character exists",
        "skill band is recorded",
        "export artifact exists"
      ],
      "knownLimitations": []
    },
